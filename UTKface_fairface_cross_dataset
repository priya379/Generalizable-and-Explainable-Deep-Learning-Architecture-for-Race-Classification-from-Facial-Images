plt.subplot(1,2,1)
plt.plot(fine_tune_history.history['accuracy'], 'b-', label='Train Accuracy', linewidth=2)
plt.plot(fine_tune_history.history['val_accuracy'], 'r-', label='Val Accuracy', linewidth=2)
plt.xlabel('Epoch')
plt.ylabel('Accuracy')
plt.title('Phase 2: Training & Validation Accuracy')
plt.legend()

plt.subplot(1,2,2)
plt.plot(fine_tune_history.history['loss'], 'b-', label='Train Loss', linewidth=2)
plt.plot(fine_tune_history.history['val_loss'], 'r-', label='Val Loss', linewidth=2)
